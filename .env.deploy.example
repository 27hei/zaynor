# Copy to .env next to docker-compose.yml and fill in before deploying.

# REQUIRED — JWT signing secret. Generate a long random value, e.g.:
#   PowerShell: -join ((48..57)+(97..122) | Get-Random -Count 64 | % {[char]$_})
JWT_KEY=

# Public URL the browser reaches the API at (defaults to http://localhost:5286)
API_URL=http://localhost:5286

# Public origin the frontend is served from (defaults to http://localhost:8080)
FRONTEND_ORIGIN=http://localhost:8080
